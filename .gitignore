# =========================================================================
# GLOBALS
# =========================================================================
.DS_Store
*.pem
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# =========================================================================
# NEXT.JS & NODE.JS (Web Dashboard)
# =========================================================================
# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production build
/build

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# =========================================================================
# ENVIRONMENT VARIABLES (CRITICAL - DO NOT COMMIT TOKENS)
# =========================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# =========================================================================
# FLUTTER & DART (Mobile App)
# Note: Flutter otomatis memiliki .gitignore di folder smartcloches-mobile/
# Aturan di bawah ini adalah pencegahan ekstra (safeguard)
# =========================================================================
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.packages
**/build/
**/.pub-cache/
**/.pub/
**/app-profile.aab
**/app-release.aab
**/app-profile.apk
**/app-release.apk

# =========================================================================
# ARDUINO / ESP32
# =========================================================================
**/*.hex
**/*.elf
**/*.bin
**/build/
**/.vscode/arduino.json
